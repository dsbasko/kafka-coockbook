{
  "name": "usecase-09-03-clickhouse-sink",
  "config": {
    "connector.class": "com.clickhouse.kafka.connect.ClickHouseSinkConnector",
    "tasks.max": "1",

    "topics.regex": "analytics\\.(users|orders|events)",
    "topic2TableMap": "analytics.users=users, analytics.orders=orders, analytics.events=events",

    "hostname": "usecase-09-03-clickhouse",
    "port": "8123",
    "database": "analytics",
    "username": "analytics",
    "password": "analytics",
    "ssl": "false",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "exactlyOnce": "false",
    "schemas.enable": "false",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "analytics-dlq",
    "errors.deadletterqueue.topic.replication.factor": "3",
    "errors.deadletterqueue.context.headers.enable": "true"
  }
}

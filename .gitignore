/.*
.DS_Store
Thumbs.db

!.gitignore
!.github/

# Kafka Connect plugins — устанавливаются через `make connect-install-plugins`,
# распакованные jar'ы не коммитим (большие, ~150MB+).
connect-plugins/*
!connect-plugins/.gitkeep
!connect-plugins/README.md

# Скомпилированные бинарники лекций — запускаются через `go run` или `make run`.
# Каждый bin лежит рядом с `cmd/<name>/main.go` либо в корне лекции.
lectures/*/*/quorum-status
lectures/*/*/inspect
lectures/*/*/watch-isr
lectures/*/*/load-and-watch
lectures/*/*/producer
lectures/*/*/consumer
lectures/*/*/bench-acks
lectures/*/*/forced-retry
lectures/*/*/bench
lectures/*/*/loud-member
lectures/*/*/idempotent-pg
lectures/*/*/format-bench
lectures/*/*/event-time-vs-processing-time
lectures/*/*/orders-producer
lectures/*/*/load-generator
lectures/*/*/topic-profiles
lectures/*/*/courier
lectures/*/*/mock-webhook

# Web app build artefacts (also covered by web/.gitignore, listed here
# so a stray `git add web/.next` from repo root is ignored).
web/node_modules/
web/.next/
web/out/
web/public/static/lectures/
